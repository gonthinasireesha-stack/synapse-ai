# ===== SERVER CONFIG =====
PORT=5000
NODE_ENV=development

# ===== DATABASE =====
DATABASE_URL=postgresql://synapse_user:synapse_pass@localhost:5432/synapse_db

# ===== AUTH =====
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===== GEMINI API =====
GEMINI_API_KEY=replace_with_your_gemini_api_key

# ===== FILE STORAGE =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ===== CLIENT (Vite exposes only VITE_ prefixed vars) =====
VITE_API_BASE_URL=http://localhost:5000/api